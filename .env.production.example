# ==========================================
# CoinOS Edge Orchestration Platform
# Production Secrets Template (.env.production)
# ==========================================
# WARNING: Do not commit the actual .env.production file to version control.
# Inject these keys securely via AWS Secrets Manager or ECS Task Definitions.

# [1] Database Integration (AWS Aurora Serverless v2 PostgreSQL)
DATABASE_URL="postgres://db_user:db_password@aurora-cluster-url.eu-west-1.rds.amazonaws.com:5432/coinos_core?sslmode=require"

# [2] Event Bus Integration (AWS MSK / Confluent Cloud)
KAFKA_BROKER_URL="pkc-abcd1.eu-west-1.aws.confluent.cloud:9092"
KAFKA_API_KEY="your_confluent_api_key"
KAFKA_API_SECRET="your_confluent_api_secret"

# [3] Liquidity Off-Boarding (M-Pesa B2C Gateway)
MPESA_CONSUMER_KEY="your_safaricom_consumer_key"
MPESA_CONSUMER_SECRET="your_safaricom_consumer_secret"
MPESA_ENVIRONMENT="production"

# [4] Internal Cryptography
# RSA Private Key used by the Escrow Engine to verify QA Oracle signatures
ESCROW_VERIFICATION_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n..."
